<!DOCTYPE html>
<html>
<head>
  <title>GizmoClinic Blog</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <h1>GizmoClinic Blog</h1>
  <% if (posts.length === 0) { %>
    <p>No posts yet.</p>
  <% } %>
  <% posts.forEach(post => { %>
    <div class="post-card">
      <h2><a href="/post/<%= post._id %>"><%= post.title %></a></h2>
      <p><%= post.excerpt %></p>
      <small><%= post.date.toDateString() %></small>
    </div>
  <% }) %>
</body>
</html>
